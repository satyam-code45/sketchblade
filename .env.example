# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored. This file is safe to commit.

# ── Database ─────────────────────────────────────────────────────────────────
# Get a free PostgreSQL URL at https://neon.tech or use a local instance.
DATABASE_URL="postgresql://user:password@host:5432/sketchblade?sslmode=require"

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ── Backend Ports (optional — defaults used if omitted) ──────────────────────
PORT=4000
WS_PORT=8080

# ── Frontend URLs (optional — defaults to localhost) ─────────────────────────
# Update these for staging/production deployments.
NEXT_PUBLIC_HTTP_BACKEND=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:8080
