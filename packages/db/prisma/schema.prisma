generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

// Second generator so the Next.js app has its own local Prisma client.
// This puts the binary inside the app directory — exactly where Next.js
// serverless functions look for it at runtime on Vercel.
generator clientNextjs {
  provider      = "prisma-client-js"
  output        = "../../../apps/excalidraw-frontend/src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  name     String
  photo    String?

  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt
  Room      Room[]
  Chat      Chat[]
}

model Room {
  id       Int     @id @default(autoincrement())
  slug     String  @unique
  name     String?
  adminId  String
  admin    User    @relation(fields: [adminId], references: [id])
  password String?

  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt
  Chat      Chat[]
}

model Chat {
  id Int @id @default(autoincrement())

  message String

  roomId Int
  room   Room @relation(fields: [roomId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])
}
